# Database (Railway provides this automatically when you add a MySQL plugin)
DATABASE_URL=mysql://user:password@host:3306/dbname

# Auth — generate a random 32+ character string
JWT_SECRET=change-me-to-a-long-random-secret

# Initial admin account (created automatically on first boot)
ADMIN_EMAIL=admin@yourdomain.com
ADMIN_PASSWORD=change-me-to-a-strong-password

# AI features — required for Lab Assistant, Research Tools, Research Intelligence.
# Works with any OpenAI-compatible API. Provide the API key here.
OPENAI_API_KEY=
# Provider endpoint. Examples:
#   OpenAI:       https://api.openai.com
#   Google Gemini: https://generativelanguage.googleapis.com/v1beta/openai
#   Groq:         https://api.groq.com/openai/v1
OPENAI_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai
# Model name for the chosen provider (e.g. gemini-2.5-flash, gpt-4o-mini, llama-3.3-70b-versatile)
LLM_MODEL=gemini-2.5-flash

# AWS S3 — optional, only needed for image storage features
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_BUCKET=
AWS_REGION=us-east-1
