# Database (Railway provides this automatically when you add a MySQL plugin)
DATABASE_URL=mysql://user:password@host:3306/dbname

# Auth — generate a random 32+ character string
JWT_SECRET=change-me-to-a-long-random-secret

# Initial admin account (created automatically on first boot)
ADMIN_EMAIL=admin@yourdomain.com
ADMIN_PASSWORD=change-me-to-a-strong-password

# AI features — required for chemical identification, lab assistant, protocol generation
OPENAI_API_KEY=sk-...
# Optional: override if using a compatible provider (e.g. Azure OpenAI, local Ollama)
# OPENAI_BASE_URL=https://api.openai.com

# AWS S3 — optional, only needed for image storage features
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_BUCKET=
AWS_REGION=us-east-1
